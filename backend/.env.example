# ==========================================
# CONFIGURACIÓN DEL SERVIDOR
# ==========================================
PORT=3003
FRONTEND_URL=http://localhost:5173

# ==========================================
# BASE DE DATOS PostgreSQL
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=retorno360db
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ==========================================
# ALMACENAMIENTO
# Opciones: "local" (pruebas) | "r2" (producción)
# ==========================================
STORAGE_MODE=local

# ==========================================
# CLOUDFLARE R2 (solo cuando STORAGE_MODE=r2)
# ==========================================
R2_ACCOUNT_ID=tu_account_id_cloudflare
R2_ACCESS_KEY_ID=tu_r2_access_key
R2_SECRET_ACCESS_KEY=tu_r2_secret_key
R2_BUCKET_NAME=retorno360-files
R2_PUBLIC_URL=https://tu-bucket.r2.dev
